{
  "name": "@vctqs1/nav-progress-bar",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vctqs1/nav-progress-bar.git",
    "directory": "packages/nav-progress-bar"
  },
  "description": "A zero-dependency, CSP-safe top-of-page progress bar built as a native Web Component",
  "homepage": "https://nav-progress-bar.vercel.app",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "license": "MIT",
  "keywords": [
    "@vctqs1/nav-progress-bar",
    "nav-progress-bar",
    "react progress bar",
    "navigation progress bar",
    "route progress bar",
    "toploader",
    "nextjs-toploader",
    "nextjs toploader",
    "nextjs top loader",
    "nextjs progress bar",
    "app router progress bar",
    "route transition loader",
    "progress-bar",
    "navigation",
    "nextjs",
    "app-router",
    "loading",
    "csp",
    "zero-dependency"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "nx": {
    "name": "@vctqs1/nav-progress-bar",
    "projectType": "library"
  }
}
